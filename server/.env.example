PORT=4000

# Postgres. Neon: copy the pooled connection string from the dashboard.
DATABASE_URL=postgres://ats:ats@localhost:5432/bsg_ats

JWT_SECRET=change-this-to-a-long-random-string

# Resume scoring. Leave blank and everything still works — resumes are just stored, not scored.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Where resumes, job descriptions and offer letters live.
#   local    — a directory on disk. NOT safe on Render: a redeploy wipes it.
#   s3       — any S3-compatible bucket: Cloudflare R2, AWS S3, Backblaze, MinIO
#   onedrive — the group's OneDrive, via Microsoft Graph (see GRAPH_* below)
STORAGE_DRIVER=onedrive
UPLOAD_DIR=./uploads

# Only needed when STORAGE_DRIVER=s3
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ---- OneDrive, via Microsoft Graph (app-only) ----
# Azure app registration with the APPLICATION permission Files.ReadWrite.All, admin-consented.
# Same pattern as the other group portals.
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_DRIVE_USER=hr@bharatsteels.in
GRAPH_ROOT_FOLDER=ATS
GRAPH_WORKBOOK_NAME=Bharat Steel Group - Employee Master.xlsx

# The frontend's address. Used to build the interview-day form links, and to lock down CORS.
PUBLIC_WEB_URL=http://localhost:5173
WEB_ORIGINS=http://localhost:5173

SEED_PASSWORD=Bharat@2026
